# ─────────────────────────────────────────────────────────────────────────────
# VoiceAgentCloud — Environment Variable Reference
#
# Copy this file to .env and fill in the values that apply to your setup.
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# NVIDIA API KEY  (required for NVCF cloud Riva ASR + TTS + NIM LLM)
# Get yours free at: https://build.nvidia.com  → API Keys
# When set, the server uses NVIDIA cloud gRPC — no local Riva Docker needed.
# When NOT set, the server falls back to local Riva (RIVA_SERVER_URL below).
# ─────────────────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────────────────
# NVIDIA Riva  — LOCAL server (only used when NVIDIA_API_KEY is NOT set)
# ─────────────────────────────────────────────────────────────────────────────
RIVA_SERVER_URL=localhost:50051
RIVA_USE_SSL=false
# RIVA_SSL_CERT=/path/to/cert.pem   # only needed if RIVA_USE_SSL=true

RIVA_ASR_LANGUAGE=en-US
RIVA_ASR_SAMPLE_RATE=16000

RIVA_TTS_VOICE=English-US.Female-1
RIVA_TTS_LANGUAGE=en-US
RIVA_TTS_SAMPLE_RATE=22050


# ─────────────────────────────────────────────────────────────────────────────
# LLM — Ollama  (primary, runs locally)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull llama3.2:1b
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_MAX_TOKENS=150


# ─────────────────────────────────────────────────────────────────────────────
# LLM — Anthropic Claude  (fallback when Ollama AND NVIDIA_API_KEY are absent)
# Get key: https://console.anthropic.com
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────────────────
# RAG — FAISS knowledge base
# ─────────────────────────────────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_DOCS_DIR=./docs
RAG_INDEX_PATH=./faiss_index
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.3
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50


# ─────────────────────────────────────────────────────────────────────────────
# Conversation memory
# ─────────────────────────────────────────────────────────────────────────────
MEMORY_MAX_TURNS=8


# ─────────────────────────────────────────────────────────────────────────────
# Audio / VAD
# ─────────────────────────────────────────────────────────────────────────────
VAD_RMS_THRESHOLD=0.018   # raise to ignore background noise, lower to be more sensitive


# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info   # debug | info | warning | error
